# ========== 前端构建 (web/) ==========
# API 基础地址，不要加 /api 后缀（接口路径已包含 /api）
VITE_API_BASE=https://zhidu.dangaogm.com

# ========== 后端 (server/) ==========
PORT=3100
NODE_ENV=production

# 生产环境允许 dev token（仅用于 demo/MVP，正式上线需接入真实登录）
ALLOW_DEV_TOKEN=true

JWT_SECRET=your-secret-change-in-production
# JWT_ISSUER=
# JWT_AUDIENCE=

# Tavily 搜索 API Key（可选）
# TAVILY_API_KEY=
